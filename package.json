{
  "name": "tpf-hrs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Hybrid Readiness Score (HRS) — fitness-benchmarking engine + app for CrossFit / hybrid athletes. Standalone off-shoot of the Operational Readiness Score (ORS).",
  "scripts": {
    "codegen": "node scripts/codegen.mjs && node scripts/codegen-operator.mjs",
    "seed": "node scripts/seed-standards.mjs",
    "build:operator-standards": "node scripts/build-operator-standards.mjs",
    "predev": "npm run codegen",
    "dev": "vite",
    "prebuild": "npm run codegen",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:supabase": "node --env-file=.env.local scripts/check-supabase.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@vercel/analytics": "^1.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "xlsx": "^0.18.5"
  }
}
