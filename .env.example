# Supabase — the SAME project as the Take Point Fitness app, so a benchmark
# sign-up creates a shared TPF account. Copy to `.env.local` and fill in.
#
# Leave BOTH unset to run the site in anonymous-only mode (Layer 1 still works;
# accounts/sync are disabled). The app builds and runs either way.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
